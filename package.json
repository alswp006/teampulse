{
  "name": "teampulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "postbuild": "node scripts/verify-no-dev-leak.mjs dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
